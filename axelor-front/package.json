{
  "name": "axelor-front",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "engines": {
    "node": ">=24.13.0"
  },
  "engineStrict": true,
  "scripts": {
    "dev": "vite --config vite-dev.config.ts",
    "clean": "rimraf dist",
    "build": "tsc && vite build",
    "build:visualizer": "tsc && VITE_VISUALIZER=true vite build",
    "build:staging": "tsc && vite build --config vite-staging.config.ts",
    "preview": "vite preview",
    "format": "prettier --write \"**/*.{ts,tsx,md,json,css,scss,html}\"",
    "test": "vitest",
    "lint": "eslint src",
    "flags": "scripts/flags/generate_combined_flags_and_css.sh",
    "svgo": "svgo --multipass src/assets/*.svg"
  },
  "dependencies": {
    "@axelor/ui": "0.6.5",
    "@babel/standalone": "^7.29.2",
    "@fullcalendar/core": "^6.1.20",
    "@fullcalendar/daygrid": "^6.1.20",
    "@fullcalendar/interaction": "^6.1.20",
    "@fullcalendar/react": "^6.1.20",
    "@fullcalendar/timegrid": "^6.1.20",
    "@monaco-editor/react": "^4.7.0",
    "@uiw/color-convert": "^2.9.6",
    "@uiw/react-color-block": "^2.9.6",
    "@uiw/react-color-chrome": "^2.9.6",
    "bootstrap-sass": "2.3.2",
    "bunshi": "^2.2.0",
    "color": "^5.0.3",
    "date-fns": "^4.1.0",
    "dayjs": "^1.11.20",
    "dompurify": "^3.3.3",
    "echarts": "^6.0.0",
    "immer": "^11.1.4",
    "jotai": "^2.19.0",
    "jotai-family": "^1.0.1",
    "jotai-immer": "^0.4.3",
    "libphonenumber-js": "^1.12.40",
    "lodash": "^4.17.23",
    "monaco-editor": "^0.52.2",
    "parse5": "^8.0.0",
    "react": "^19.2.4",
    "react-datepicker": "^9.1.0",
    "react-dom": "^19.2.4",
    "react-error-boundary": "^6.1.1",
    "react-grid-layout": "2.2.3",
    "react-international-phone": "^4.8.0",
    "react-router": "^7.13.2",
    "react-transition-group": "^4.4.5",
    "signature_pad": "^5.1.3",
    "swagger-ui-react": "^5.32.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/lodash": "^4.17.24",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-transition-group": "^4.4.12",
    "@types/swagger-ui-react": "^5.18.0",
    "@vitejs/plugin-react": "^5.1.4",
    "eslint": "^10.1.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jotai-babel": "^0.1.0",
    "jsdom": "^29.0.1",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "rollup-plugin-visualizer": "^7.0.1",
    "sass": "1.77.8",
    "svgo": "^4.0.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2",
    "vite": "^7.3.1",
    "vite-plugin-svgr": "^4.5.0",
    "vitest": "^4.1.1"
