<?xml version="1.0" ?>
<domain-models xmlns="http://axelor.com/xml/ns/domain-models"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://axelor.com/xml/ns/domain-models https://axelor.com/xml/ns/domain-models/domain-models_8.2.xsd">

  <module name="test" package="com.axelor.test.db"/>

  <entity name="StrategyJoined" strategy="JOINED" table="STRATEGY_JOINED">

    <string name="myString"/>
    <string name="mySecureString" encrypted="true"/>

  </entity>

  <entity name="StrategyJoinedChild" extends="StrategyJoined" table="STRATEGY_JOINED_CHILD">

    <string name="myStringChild"/>
    <string name="mySecureStringChild" encrypted="true"/>

  </entity>

</domain-models>
