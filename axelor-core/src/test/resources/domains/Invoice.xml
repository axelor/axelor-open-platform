<?xml version="1.0" ?>
<domain-models xmlns="http://axelor.com/xml/ns/domain-models"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://axelor.com/xml/ns/domain-models https://axelor.com/xml/ns/domain-models/domain-models_8.2.xsd">

  <module name="test" package="com.axelor.test.db"/>

  <entity name="Invoice" table="TEST_INVOICE">

    <many-to-one name="move" ref="Move"/>
    <many-to-one name="oldMove" ref="Move"/>
    <many-to-one name="rejectMoveLine" ref="MoveLine"/>
    <many-to-one name="saleUser" ref="com.axelor.auth.db.User"/>
    <many-to-many name="members" ref="com.axelor.auth.db.User"/>

    <date name="date" column="invoice_date"/>
    <date name="dueDate"/>

  </entity>

</domain-models>
